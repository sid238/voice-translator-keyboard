{
  "cli": {
    "version": ">= 9.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "image": "latest"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "image": "latest"
      }
    },
    "production": {
      "android": {
        "image": "latest",
        "buildType": "release",
        "gradleCommand": ":app:assembleRelease"
      }
    },
    "production-arm64": {
      "extends": "production",
      "android": {
        "gradleCommand": ":app:assembleRelease",
        "buildType": "apk"
      }
    },
    "production-armeabi": {
      "extends": "production",
      "android": {
        "gradleCommand": ":app:assembleRelease",
        "buildType": "apk"
      }
    },
    "production-x86_64": {
      "extends": "production",
      "android": {
        "gradleCommand": ":app:assembleRelease",
        "buildType": "apk"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
